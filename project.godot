[layer_names]

2d_physics/layer_1="player_walkbox"
2d_physics/layer_2="enemies"
2d_physics/layer_3="player_bullets"
2d_physics/layer_4="enemy_bullet"
2d_physics/layer_5="floor"
2d_physics/layer_6="player_hitbox"
